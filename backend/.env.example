# PostgreSQL connection string
# On Railway: automatically injected when you add the PostgreSQL plugin
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT signing secrets — use long random strings in production
JWT_SECRET="your-strong-jwt-secret-here"
JWT_REFRESH_SECRET="your-strong-jwt-refresh-secret-here"

# Port — Railway sets this automatically, do NOT override
# PORT=3001

# Environment
NODE_ENV="production"
